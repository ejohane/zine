{
  "name": "zine",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.4",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "build:ios": "bun run --cwd apps/mobile build:ios",
    "deploy:ios:production": "bun run --cwd apps/mobile deploy:ios:production",
    "deploy:ios:testflight:local": "bun run --cwd apps/mobile deploy:ios:testflight:local",
    "dev": "turbo run dev",
    "dev:web": "bun run --cwd apps/web dev",
    "dev:worktree": "./scripts/dev.sh",
    "data:prod:local": "bun run ./scripts/sync-prod-user-to-local.mjs",
    "data:people-names:prod": "bun run ./scripts/repair-prod-people-display-names.mjs",
    "design-system:check": "node ./scripts/check-mobile-design-system.mjs",
    "storybook:mobile": "bun run --cwd apps/mobile storybook",
    "storybook:web": "bun run --cwd apps/web storybook",
    "dev:reset": "./scripts/dev-reset.sh",
    "diag:health": "bun run ./scripts/diag-health.mjs",
    "diag:cf:logs": "bun run ./scripts/diag-cf-logs.mjs",
    "diag:release": "bun run ./scripts/diag-release.mjs",
    "diag:queue:dlq": "bun run ./scripts/diag-queue-dlq.mjs",
    "diag:incident": "bun run ./scripts/diag-incident.mjs",
    "x:archive:test": "bun run --cwd apps/x-archive test:run && bun run --cwd apps/x-collector test",
    "x:archive:receive": "bun run --cwd apps/x-collector receive",
    "editorial:test": "bun run --cwd packages/editorial-schema test && bun run --cwd apps/editorial test",
    "editorial:snapshot": "bun run ./apps/editorial/src/cli.ts snapshot",
    "editorial:rank": "bun run ./apps/editorial/src/cli.ts rank",
    "editorial:replay": "bun run ./apps/editorial/src/cli.ts replay",
    "editorial:portfolio:override": "bun run ./apps/editorial/src/cli.ts portfolio-override",
    "editorial:run:start": "bun run ./apps/editorial/src/cli.ts run-start",
    "editorial:run:fail": "bun run ./apps/editorial/src/cli.ts run-fail",
    "editorial:validate": "bun run ./apps/editorial/src/cli.ts validate",
    "editorial:render": "bun run ./apps/editorial/src/cli.ts render",
    "editorial:publish": "bun run ./apps/editorial/src/cli.ts publish",
    "editorial:experiment:create": "bun run ./apps/editorial/src/cli.ts experiment-create",
    "editorial:experiment:update": "bun run ./apps/editorial/src/cli.ts experiment-update",
    "editorial:experiment:status": "bun run ./apps/editorial/src/cli.ts experiment-status",
    "editorial:experiment:lock": "bun run ./apps/editorial/src/cli.ts experiment-lock",
    "editorial:experiment:fail": "bun run ./apps/editorial/src/cli.ts experiment-fail",
    "editorial:experiment:abandon": "bun run ./apps/editorial/src/cli.ts experiment-abandon",
    "editorial:experiment:variant:publish": "bun run ./apps/editorial/src/cli.ts experiment-variant-publish",
    "editorial:experiment:decide": "bun run ./apps/editorial/src/cli.ts experiment-decide",
    "editorial:experiment:promote": "bun run ./apps/editorial/src/cli.ts experiment-promote",
    "test": "bun run test:mobile && bun run test:worker && bun run test:web",
    "test:mobile": "bun run --cwd apps/mobile test",
    "test:web": "bun run --cwd apps/web test",
    "test:web:storybook": "bun run --cwd apps/web storybook:test",
    "test:web:e2e": "bun run --cwd apps/web test:e2e",
    "test:web:ci": "bun run test:web && bun run test:web:storybook && bun run test:web:e2e",
    "test:worker": "bun run --cwd apps/worker test:run",
    "test:worker:ci": "bun run --cwd apps/worker test:run --exclude='**/user-do.test.ts' --exclude='**/scheduler.test.ts'",
    "test:observability": "bun test ./scripts/lib/observability.test.ts",
    "observability:check": "bun run ./scripts/observability-checks.mjs",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{js,jsx,json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "eslint": "^9.16.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.49.0"
  }
}
