{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "types": [
      "vite/client",
      "vitest/globals",
      "@testing-library/jest-dom",
      "@cloudflare/workers-types"
    ],
    "paths": {
      "@/*": ["./src/*"],
      "@zine/design-system": ["../../packages/design-system/src/index.ts"],
      "@zine/design-system/*": ["../../packages/design-system/src/*"],
      "@zine/shared": ["../../packages/shared/src/index.ts"],
      "@zine/shared/*": ["../../packages/shared/src/*"],
      "@zine/worker/*": ["../worker/src/*"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.tsx", "vite.config.ts", "vitest.config.ts"]
}
