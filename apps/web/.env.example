# Zine Web App Environment Variables
#
# For development: Copy to .env.local and fill in your values

# =============================================================================
# Clerk Authentication
# =============================================================================
# Get this from Clerk Dashboard > API Keys > Publishable Key
# Use a development key for local web work.
VITE_CLERK_PUBLISHABLE_KEY=pk_test

# =============================================================================
# API Configuration
# =============================================================================
# Leave unset in your checked-in template. scripts/dev.sh injects VITE_API_URL
# into apps/web/.env.local for the current worktree each time you run
# bun run dev:worktree.
# VITE_API_URL=http://localhost:8787

# =============================================================================
# OAuth Provider Client IDs
# =============================================================================
VITE_SPOTIFY_CLIENT_ID=your_spotify_client_id
VITE_YOUTUBE_CLIENT_ID=your_google_client_id
