{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "paths": {
      "@/*": ["./*"],
      "@zine/design-system": ["../../packages/design-system/src/index.ts"],
      "@zine/design-system/*": ["../../packages/design-system/src/*"],
      "@zine/shared": ["../../packages/shared/src/index.ts"],
      "@zine/shared/*": ["../../packages/shared/src/*"],
      "@zine/worker/*": ["../worker/src/*"],
      "@testing-library/react-hooks": ["./test-utils/react-hooks.ts"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx", ".expo/types/**/*.ts", "expo-env.d.ts"]
}
