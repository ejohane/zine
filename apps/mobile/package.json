{
  "name": "@zine/mobile",
  "main": "index.js",
  "version": "1.0.0",
  "scripts": {
    "design-system:check": "node ../../scripts/check-mobile-design-system.mjs",
    "dev": "EXPO_PUBLIC_STORYBOOK_ENABLED=true expo start -c --port ${METRO_PORT:-8081}",
    "storybook:start": "EXPO_PUBLIC_STORYBOOK_ENABLED=true expo start -c --port ${METRO_PORT:-8081}",
    "storybook:generate": "sb-rn-get-stories",
    "start": "expo start -c",
    "android": "expo start --android -c",
    "ios": "expo start --ios -c",
    "web": "expo start --web -c",
    "lint": "expo lint && bun run design-system:check",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "build:ios:preview": "env -u EXPO_PUBLIC_STORYBOOK_ENABLED EXPO_NO_DOTENV=1 dotenv -e .env.preview -- env EXPO_PUBLIC_API_URL=https://api.myzine.app eas build --platform ios --profile preview --local --output ./build/preview.ipa --non-interactive",
    "deploy:ios:production": "eas build --platform ios --profile production --auto-submit --non-interactive",
    "deploy:ios:testflight:local": "./scripts/deploy-testflight-local.sh",
    "deploy:ios:preview": "./scripts/build-and-install-ios.sh"
  },
  "dependencies": {
    "@clerk/clerk-expo": "^2.19.11",
    "@expo/dom-webview": "^56.0.5",
    "@expo/ui": "~56.0.15",
    "@expo/vector-icons": "^15.0.2",
    "@gorhom/bottom-sheet": "^5.2.6",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-community/datetimepicker": "9.1.0",
    "@react-native-community/netinfo": "12.0.1",
    "@react-native-community/slider": "5.2.0",
    "@tanstack/query-async-storage-persister": "^5.60.0",
    "@tanstack/react-query": "^5.60.0",
    "@tanstack/react-query-persist-client": "^5.60.0",
    "@trpc/client": "^11.0.0",
    "@trpc/react-query": "^11.0.0",
    "@zine/design-system": "workspace:*",
    "@zine/shared": "workspace:*",
    "expo": "~56.0.8",
    "expo-auth-session": "~56.0.13",
    "expo-constants": "~56.0.16",
    "expo-crypto": "~56.0.4",
    "expo-font": "~56.0.5",
    "expo-haptics": "~56.0.3",
    "expo-image": "~56.0.9",
    "expo-linear-gradient": "~56.0.4",
    "expo-linking": "~56.0.13",
    "expo-router": "~56.2.8",
    "expo-secure-store": "~56.0.4",
    "expo-sharing": "~56.0.15",
    "expo-splash-screen": "~56.0.10",
    "expo-status-bar": "~56.0.4",
    "expo-symbols": "~56.0.5",
    "expo-system-ui": "~56.0.5",
    "expo-web-browser": "~56.0.5",
    "heroui-native": "^1.0.0-beta.8",
    "lucide-react-native": "^0.577.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-context-menu-view": "^1.21.0",
    "react-native-draggable-flatlist": "^4.0.3",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "15.15.4",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.8.3",
    "superjson": "^2.2.0",
    "tailwind-merge": "^3.4.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.1.17",
    "ulid": "^3.0.2",
    "uniwind": "^1.2.2"
  },
  "devDependencies": {
    "@storybook/addon-ondevice-actions": "^10.2.3",
    "@storybook/addon-ondevice-backgrounds": "^10.2.3",
    "@storybook/addon-ondevice-controls": "^10.2.3",
    "@storybook/addon-ondevice-notes": "^10.2.3",
    "@storybook/react-native": "^10.2.3",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "~29.5.14",
    "@types/react": "~19.2.10",
    "dotenv": "^17.2.3",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~56.0.4",
    "jest": "~29.7.0",
    "jest-environment-jsdom": "~29.7.0",
    "react-test-renderer": "19.2.3",
    "storybook": "^10.2.10",
    "ts-jest": "^29.4.6",
    "typescript": "~6.0.3"
  },
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "listUnknownPackages": false
      }
    }
  },
  "private": true
}
